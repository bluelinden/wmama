# Discord bot token (Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=

# Discord application (client) ID (Developer Portal -> General Information)
DISCORD_APPLICATION_ID=

# Discord interactions public key (Developer Portal -> General Information)
DISCORD_PUBLIC_KEY=

# Optional: register slash commands to a single guild for instant updates during development.
# If omitted, commands register globally (can take up to ~1 hour to show up).
DISCORD_GUILD_ID=
